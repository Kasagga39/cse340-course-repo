<%- include('partials/header') %>
<main class="dashboard-page">
    <div class="content-header">
        <h1>Dashboard</h1>
    </div>

    <div class="project-grid">
        <div class="project-main">
            <div class="sidebar-card mb-6">
                <h2>Welcome, <%= name %>!</h2>
                <p>You are logged in as: <strong><%= email %></strong></p>
                <p>Your Role: <span class="status-badge"><%= role %></span></p>
            </div>

            <div class="card-actions">
                <a href="/projects" class="button"><i data-lucide="briefcase" class="icon-sm"></i> Browse Projects</a>
                <% if (role === 'admin') { %>
                    <a href="/users" class="button button-outline"><i data-lucide="users" class="icon-sm"></i> Manage Users</a>
                <% } %>
            </div>
        </div>

        <div class="project-sidebar">
            <div class="sidebar-card">
                <h3>Account Summary</h3>
                <p>Manage your account settings and view your service activity.</p>
                <div class="project-footer">
                    <a href="/logout" class="button button-edit"><i data-lucide="log-out" class="icon-sm"></i> Log Out</a>
                </div>
            </div>
        </div>
    </div>
</main>
<%- include('partials/footer') %>
