<%- include('partials/header') %>
<main class="form-page">
    <div class="form-container">
        <div class="form-header">
            <h1><%= title %></h1>
            <p>Join the CSE 340 Service Network today.</p>
        </div>

        <form action="/register" method="POST">
            <div class="form-group">
                <label for="name">Full Name</label>
                <input type="text" id="name" name="name" required placeholder="Enter your full name">
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required placeholder="Enter your email address">
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required minlength="8" placeholder="Create a strong password">
            </div>

            <div class="form-actions">
                <button type="submit" class="submit-btn"><i data-lucide="user-plus" class="icon-sm"></i> Create Account</button>
                <p class="form-footer-text">Already have an account? <a href="/login">Log in here</a></p>
            </div>
        </form>
    </div>
</main>
<%- include('partials/footer') %>
